{
  "manifest_version": 3,
  "name": "ReelPlus",
  "version": "1.0.0",
  "description": "Adds simple video, volume, and mute controls to Instagram Reels.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/reels/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ]
}