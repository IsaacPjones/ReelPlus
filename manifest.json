{
  "manifest_version": 3,
  "name": "ReelPlus",
  "version": "1.0.0",
  "description": "Adds draggable playback, replay, mute, volume, and seek controls for Instagram Reels.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/reels/*"],
      "js": ["content.js"],
      "css": ["styles.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}